<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Capsa Order List</masterLabel>
    <description>Lists the logged-in account's store orders with a clickable order number that opens its Order Summary.</description>
    <targets>
        <target>lightningCommunity__Page</target>
        <target>lightningCommunity__Default</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightningCommunity__Default">
            <property name="heading" type="String" label="Heading" default="Orders" />
            <property name="pageSize" type="Integer" label="Rows per page" default="10" min="1" max="100" />
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>